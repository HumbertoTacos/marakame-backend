  MORAL
}

enum CondicionesPagoProveedor {
  CONTADO
  CREDITO_15
  CREDITO_30
}

enum MonedaProveedor {
  MXN
  USD
  EUR
}

model Proveedor {
  id Int @id @default(autoincrement())

  // ─── DATOS GENERALES ────────────────────────────────────────
  nombre              String               @unique
  razonSocial         String?
  rfc                 String?              @unique
  curp                String?
  tipo                TipoProveedor?
  giro                GiroProveedor?
  tipoPersona         TipoPersonaProveedor?
  estadoProveedor     EstadoProveedor      @default(ACTIVO)
  activo              Boolean              @default(true)

  // ─── CONTACTO ────────────────────────────────────────────────
  contactoPrincipal   String?
  cargoContacto       String?
  telefono            String?
  celular             String?
  correo              String?
  paginaWeb           String?

  // ─── DIRECCIÓN FISCAL ────────────────────────────────────────
  pais                String?
  estadoRepublica     String?
  ciudad              String?
  colonia             String?
  calle               String?
  numExterior         String?
  numInterior         String?
  codigoPostal        String?
  referencias         String?
  direccion           String?

  // ─── INFORMACIÓN BANCARIA ─────────────────────────────────────
  banco               String?
  cuentaBancaria      String?
  clabe               String?
  metodoPago          String?
  condicionesPago     CondicionesPagoProveedor?
  moneda              MonedaProveedor?
  diasCredito         Int?

  // ─── INFORMACIÓN FISCAL ──────────────────────────────────────
  regimenFiscal       String?
  usoCFDI             String?
  metodoFacturacion   String?
  retencionesAplicables String?
  constanciaFiscalUrl String?

  // ─── PRODUCTOS / SERVICIOS ───────────────────────────────────
  productosServicios  String?   @db.Text
  marcas              String?
  tiempoEntregaPromedio String?
  garantias           String?
  convenios           String?   @db.Text

  // ─── DOCUMENTOS ──────────────────────────────────────────────
  ineRepresentanteUrl     String?
  actaConstitutivaUrl     String?
  comprobanteDomicilioUrl String?
  contratoUrl             String?
  catalogoProductosUrl    String?

  // ─── DATOS INTERNOS ──────────────────────────────────────────
  calificacion        Int?
  observaciones       String?
  notas               String?   @db.Text
  ultimaCompra        DateTime?

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // ─── RELACIONES ──────────────────────────────────────────────
  comprasSeleccionadas CompraRequisicion[] @relation("ProveedorSeleccionadoCompra")
  cotizaciones         CompraCotizacion[]
  ordenes              CompraOrden[]
  facturas             CompraFactura[]
  contraRecibos        ContraRecibo[]
  ordenesPagoDetalle   CompraOrdenPagoDetalle[]
  expedientesFinalizados CompraExpedienteFinalizado[] @relation("ExpedientesFinalizados")

  @@index([activo])
  @@index([estadoProveedor])
  @@index([nombre])
  @@index([giro])
  @@map("proveedores")
}

