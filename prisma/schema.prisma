// PRODUCTOS

model AlmacenProducto {
  id Int @id @default(autoincrement())

  codigo String @unique

  nombre String

  descripcion String?

  categoria CategoriaProducto

  unidad String

  stockActual Int @default(0)

  stockMinimo Int @default(5)

  estadoStock EstadoStock @default(NORMAL)

  ubicacion String?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // RELACIONES

  movimientos AlmacenMovimiento[]

  lotes AlmacenLote[]

  requisicionesDetalle RequisicionDetalle[]

  compraDetalles CompraDetalle[]

  @@index([estadoStock])
  @@index([categoria])
  @@map("almacen_productos")
}

// REQUISICIONES

model Requisicion {
  id Int @id @default(autoincrement())

  folio String @unique

  usuarioSolicitaId Int

  areaSolicitante String

  tipo TipoCompra @default(ORDINARIA)

  estado EstadoRequisicion @default(CREADA)

  descripcion String?

  justificacion String

  tieneExistencia Boolean?

  observaciones String?

  revisadoAlmacenPorId Int?

  autorizadoPorId Int?

  fechaRevisionAlmacen DateTime?

  fechaAutorizacion DateTime?

  revisadoAdministracionPorId Int?

  fechaRevisionAdministracion DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  fechaRechazo DateTime?

  rechazadaPorDireccion Boolean @default(false)

  // RELACIONES

  usuarioSolicita           Usuario  @relation("UsuarioSolicitaRequisicion", fields: [usuarioSolicitaId], references: [id])
  revisadoAlmacenPor        Usuario? @relation("RequisicionesRevisadasAlmacen", fields: [revisadoAlmacenPorId], references: [id])
  autorizadoPor             Usuario? @relation("RequisicionesAutorizadas", fields: [autorizadoPorId], references: [id])
  revisadoAdministracionPor Usuario? @relation("RequisicionesRevisadasAdministracion", fields: [revisadoAdministracionPorId], references: [id])

  detalles           RequisicionDetalle[]
  historial          RequisicionHistorial[]
  movimientosAlmacen AlmacenMovimiento[]    @relation("MovimientoRequisicion")
  compraRequisicion  CompraRequisicion?

  @@index([estado])
  @@index([areaSolicitante])
  @@map("requisiciones")
}

model RequisicionDetalle {
  id Int @id @default(autoincrement())

  requisicionId Int

  productoId Int?

  productoNombre String?

  unidadLibre String?

  numero Int @default(0)

  cantidadSolicitada Int

  cantidadEntregada Int @default(0)

  observaciones String?

  // RELACIONES

  requisicion  Requisicion        @relation(fields: [requisicionId], references: [id])
  producto     AlmacenProducto?   @relation(fields: [productoId], references: [id])
  cotizaciones CompraCotizacion[]

  @@map("requisiciones_detalles")
}

model RequisicionHistorial {
  id Int @id @default(autoincrement())

  requisicionId Int

  usuarioId Int

  estado EstadoRequisicion

  comentario String?

  fecha DateTime @default(now())

  // RELACIONES

  requisicion Requisicion @relation(fields: [requisicionId], references: [id])
  usuario     Usuario     @relation(fields: [usuarioId], references: [id])

  @@index([requisicionId])
  @@index([fecha])
  @@map("requisiciones_historial")
}

// MOVIMIENTOS

model AlmacenMovimiento {
  id Int @id @default(autoincrement())

  productoId Int

  usuarioId Int

  requisicionId Int?

  tipo TipoMovimiento

  cantidad Int

  // ENTRADAS

  proveedor String?

  numeroFactura String?

  importeFactura Decimal? @db.Decimal(10, 2)

  facturaUrl String?

  validadoFactura Boolean @default(false)

  empaqueCorrecto Boolean?

  cantidadCorrecta Boolean?

  presentacionCorrecta Boolean?

  fechaCaducidad DateTime?

  estadoRecepcion EstadoRecepcion @default(PENDIENTE)

  motivoRechazo String?

  contraReciboUrl String?

  // SALIDAS

  areaSolicitante String?

  motivo String?

  nombreRecibe String?

  confirmadoRecibido Boolean @default(false)

  estadoSalida EstadoSalida?

  autorizadoPorId Int?

  fechaEntrega DateTime?

  // NOTIFICACIONES

  notificadoRecursos Boolean @default(false)

  fechaNotificacion DateTime?

  // GENERALES

  observaciones String?

  createdAt DateTime @default(now())

  // RELACIONES

  producto      AlmacenProducto @relation(fields: [productoId], references: [id])
  usuario       Usuario         @relation("MovimientoUsuario", fields: [usuarioId], references: [id])
  requisicion   Requisicion?    @relation("MovimientoRequisicion", fields: [requisicionId], references: [id])
  autorizadoPor Usuario?        @relation("MovimientosAutorizados", fields: [autorizadoPorId], references: [id])
  contraRecibo  ContraRecibo?

  @@index([tipo])
  @@index([createdAt])
  @@map("almacen_movimientos")
}

// LOTES

model AlmacenLote {
  id Int @id @default(autoincrement())

  productoId Int

  numeroLote String

  fechaCaducidad DateTime

  cantidad Int

  createdAt DateTime @default(now())

  producto AlmacenProducto @relation(fields: [productoId], references: [id])

