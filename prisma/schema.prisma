  contraReciboPdfUrl String?

  createdAt DateTime @default(now())

  // RELACIONES

  movimiento  AlmacenMovimiento @relation(fields: [movimientoId], references: [id])

  proveedor   Proveedor?        @relation(fields: [proveedorId], references: [id])

  recibidoPor Usuario           @relation("ContraReciboRecibidoPor", fields: [recibidoPorId], references: [id])

  @@map("contra_recibos")
}

