enum EstadoCompra {
  EN_COMPRAS

  COTIZACIONES_CARGADAS

  EN_REVISION_ADMINISTRACION
  DEVUELTA_A_COMPRAS

  EN_REVISION_DIRECCION

  AUTORIZADA

  ORDEN_GENERADA

  FACTURAS_RECIBIDAS

  EXPEDIENTE_GENERADO

  ENVIADA_A_FINANZAS

  FINALIZADO

  RECHAZADO

  // ESTADOS ANTIGUOS
  REQUISICION_CREADA
  EN_REVISION_RECURSOS
  EN_REVISION_COMPRAS
  PROVEEDOR_SELECCIONADO
  NEGOCIACION_COMPLETADA
  ORDEN_PAGO_GENERADA
  PAGO_GENERADO
  REQUISICION_REVISADA
  EN_REVISION_ADMIN
  EN_AUTORIZACION_DIRECCION
}

enum TipoCompra {
  ORDINARIA
  EXTRAORDINARIA
}

model CompraRequisicion {
  id Int @id @default(autoincrement())

  folio String @unique

  requisicionId Int @unique

  usuarioId Int

  tipo TipoCompra

  fechaRechazo DateTime?

  rechazadoPorDireccion Boolean @default(false)

  estado EstadoCompra @default(EN_COMPRAS)

  presupuestoEstimado Decimal? @db.Decimal(10, 2)

  totalFinal Decimal? @db.Decimal(10, 2)

  esCompraMayor Boolean @default(false)

  numeroCotizacionesRequeridas Int @default(1)

  expedienteGenerado Boolean @default(false)

  enviadoFinanzas Boolean @default(false)

  esUrgente Boolean @default(false)

  proveedorSeleccionadoId Int?

  formaPago String?

  tipoCredito String?

  usuarioAutorizaId Int?

  observacionesVoBo String?

  motivoRechazo String?

  devueltaPorAdministracion Boolean @default(false)

  fechaRecepcionCompras DateTime?

  fechaRevisionAdministracion DateTime?

  fechaEnvioDireccion DateTime?

  fechaRecepcionDireccion DateTime?

  fechaAutorizacion DateTime?

  fechaOrdenCompra DateTime?

  fechaRecepcionFacturas DateTime?

  fechaEnvioFinanzas DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  revisadoAdministracionPorId Int?

  // RELACIONES

  revisadoAdministracionPor Usuario?    @relation("ComprasRevisadasAdministracion", fields: [revisadoAdministracionPorId], references: [id])
  proveedorSeleccionado     Proveedor?  @relation("ProveedorSeleccionadoCompra", fields: [proveedorSeleccionadoId], references: [id])
  requisicion               Requisicion @relation(fields: [requisicionId], references: [id])
  usuario                   Usuario     @relation("CompraCreadaPor", fields: [usuarioId], references: [id])
  usuarioAutoriza           Usuario?    @relation("CompraAutorizadaPor", fields: [usuarioAutorizaId], references: [id])

  cotizaciones CompraCotizacion[]
  ordenes      CompraOrden[]
  facturas     CompraFactura[]
  pago         CompraPago?
  ordenPago    CompraOrdenPago?
  detalles     CompraDetalle[]
  historial    CompraHistorial[]
  expedientesFinalizados CompraExpedienteFinalizado[]

  @@index([estado])
  @@map("compras_requisiciones")
}

model CompraCotizacion {
  id Int @id @default(autoincrement())

  requisicionId Int

  requisicionDetalleId Int?

  proveedorId Int

  precio         Decimal  @db.Decimal(10, 2)
  precioUnitario Decimal? @db.Decimal(10, 2)

  tiempoEntrega String?

  esMejorOpcion Boolean @default(false)

  formaPago       String?
  condicionesPago String?

  tipoCredito String?

  garantia String?
  marca    String?
  modelo   String?

  observaciones String?

  documentoUrl String?

  createdAt DateTime @default(now())

  requisicion        CompraRequisicion   @relation(fields: [requisicionId], references: [id])
  requisicionDetalle RequisicionDetalle? @relation(fields: [requisicionDetalleId], references: [id])
  proveedor          Proveedor           @relation(fields: [proveedorId], references: [id])

  @@index([requisicionId])
  @@index([proveedorId])
  @@index([requisicionDetalleId])
  @@map("compras_cotizaciones")
}

model CompraOrden {
  id              Int      @id @default(autoincrement())
  requisicionId   Int
  folio           String   @unique
  fecha           DateTime @default(now())
  proveedorId     Int
  total           Decimal  @db.Decimal(10, 2)
  elaboradoPorId  Int?
  revisadoPorId   Int?
  autorizadoPorId Int?
  createdAt       DateTime @default(now())

  requisicion   CompraRequisicion @relation(fields: [requisicionId], references: [id])
  elaboradoPor  Usuario?          @relation("OrdenElaborada", fields: [elaboradoPorId], references: [id])
  revisadoPor   Usuario?          @relation("OrdenRevisada", fields: [revisadoPorId], references: [id])
  proveedor     Proveedor         @relation(fields: [proveedorId], references: [id])
  autorizadoPor Usuario?          @relation("OrdenAutorizada", fields: [autorizadoPorId], references: [id])

  @@map("compras_ordenes")
}

model CompraFactura {
  id Int @id @default(autoincrement())

  requisicionId Int

  numero String

  monto Decimal @db.Decimal(10, 2)

  documentoUrl String?

  proveedorId Int?

  createdAt DateTime @default(now())

  requisicion CompraRequisicion @relation(fields: [requisicionId], references: [id])
  proveedor   Proveedor?        @relation(fields: [proveedorId], references: [id])

  @@index([requisicionId])
  @@map("compras_facturas")
}

model CompraPago {
  id Int @id @default(autoincrement())

  requisicionId Int @unique

  total Decimal @db.Decimal(10, 2)

  fecha DateTime @default(now())

  requisicion CompraRequisicion @relation(fields: [requisicionId], references: [id])

  @@map("compras_pagos")
}

model CompraOrdenPago {
  id Int @id @default(autoincrement())

  requisicionId Int @unique

  folio String @unique

  fecha DateTime @default(now())

  asunto String?

  dirigidoA String?

  totalGeneral Decimal? @db.Decimal(10, 2)

  observaciones String?

  elaboradoPorId Int?

  revisadoPorId Int?

  autorizadoPorId Int?

  elaboradoPor  Usuario?                 @relation("OrdenPagoElaborada", fields: [elaboradoPorId], references: [id])
  revisadoPor   Usuario?                 @relation("OrdenPagoRevisada", fields: [revisadoPorId], references: [id])
  autorizadoPor Usuario?                 @relation("OrdenPagoAutorizada", fields: [autorizadoPorId], references: [id])
  requisicion   CompraRequisicion        @relation(fields: [requisicionId], references: [id])
  detalles      CompraOrdenPagoDetalle[]

  createdAt DateTime @default(now())

  @@map("compras_ordenes_pago")
}

model CompraOrdenPagoDetalle {
  id Int @id @default(autoincrement())

  ordenPagoId Int

  fechaOrdenCompra DateTime?

  folioOrdenCompra String?

  numeroFactura String?

  proveedorId Int?

  monto Decimal @db.Decimal(10, 2)

  ordenPago CompraOrdenPago @relation(fields: [ordenPagoId], references: [id])
  proveedor Proveedor?      @relation(fields: [proveedorId], references: [id])

  @@map("compras_ordenes_pago_detalles")
}

model CompraDetalle {
  id Int @id @default(autoincrement())

  requisicionId Int

  productoId Int

  numero Int

  unidad String

  cantidad Int

  requisicion CompraRequisicion @relation(fields: [requisicionId], references: [id])
  producto    AlmacenProducto   @relation(fields: [productoId], references: [id])

  @@index([requisicionId])
  @@index([productoId])
  @@map("compras_detalles")
}

model CompraHistorial {
  id Int @id @default(autoincrement())

  requisicionId Int

  estado EstadoCompra

  fecha DateTime @default(now())

  usuarioId Int

  comentario String?

  requisicion CompraRequisicion @relation(fields: [requisicionId], references: [id])
  usuario     Usuario           @relation("HistorialCompraUsuario", fields: [usuarioId], references: [id])

  @@index([requisicionId])
  @@index([fecha])
  @@map("compras_historial")
}

model CompraExpedienteFinalizado {
  id Int @id @default(autoincrement())

  folio String @unique

  requisicionId Int

  proveedorId Int

  estado EstadoCompra @default(FINALIZADO)

  totalFinal Decimal? @db.Decimal(10, 2)

  usuarioIdEnvio Int?

  usuarioIdFinalizacion Int?

  fechaEnvioFinanzas DateTime?

  fechaFinalizacion DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  requisicion CompraRequisicion @relation(fields: [requisicionId], references: [id])
  proveedor   Proveedor         @relation("ExpedientesFinalizados", fields: [proveedorId], references: [id])
  usuarioEnvio Usuario?          @relation("ExpedientesFinalizadosEnvio", fields: [usuarioIdEnvio], references: [id])
  usuarioFinalizacion Usuario?   @relation("ExpedientesFinalizadosFinalizacion", fields: [usuarioIdFinalizacion], references: [id])

  @@index([requisicionId])
  @@index([estado])
  @@index([fechaFinalizacion])
  @@map("compras_expedientes_finalizados")
}

// ============================================================
// NÓMINAS Y RECURSOS HUMANOS
// ============================================================

enum RegimenLaboral {
  CONFIANZA
  LISTA_RAYA
}

enum EstadoNomina {
  BORRADOR
  PRE_NOMINA
  SOLICITUD_SUBSIDIO
  EN_REVISION
  AUTORIZADO
  PAGADO
}

enum TipoIncidencia {
  INASISTENCIA
  RETARDO
  SALIDA_ANTICIPADA
  FALTA_JUSTIFICADA
}

model Empleado {
  id               Int            @id @default(autoincrement())
  nombre           String
  apellidos        String
  puesto           String
  departamento     String
  regimen          RegimenLaboral @default(CONFIANZA)
  salarioBase      Float
  compensacionFija Float?         @default(0)
  activo           Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  prenominas          PreNomina[]
  incidencias         IncidenciaNomina[]
  registrosAsistencia RegistroAsistencia[] // <--- SE AGREGÓ LA RELACIÓN FALTANTE

  @@map("empleados")
}

model IncidenciaNomina {
  id                 Int            @id @default(autoincrement())
  empleadoId         Int
  fecha              DateTime
  tipo               TipoIncidencia
  minutosRetardo     Int?
  justificada        Boolean        @default(false)
  vistoBuenoJefe     Boolean        @default(false)
  documentoJustifUrl String?
  descuentoAplicar   Float          @default(0)
  aplicadoEnNominaId Int?
  createdAt          DateTime       @default(now())

  empleado Empleado @relation(fields: [empleadoId], references: [id])

  @@map("incidencias_nomina")
}

model Nomina {
  id                     Int          @id @default(autoincrement())
  folio                  String       @unique
  periodo                String
  fechaInicio            DateTime
  fechaFin               DateTime
  estado                 EstadoNomina @default(BORRADOR)
  usuarioAutorizaId      Int?
  fechaAutorizacion      DateTime?
  firmaRecursosHumanos   Boolean      @default(false)
  firmaFinanzas          Boolean      @default(false)
  firmaAdministracion    Boolean      @default(false)
  firmaDireccion         Boolean      @default(false)
  fechaSolicitudSubsidio DateTime?
  fechaRecepcionRecurso  DateTime?
  totalPercepciones      Float?       @default(0)
  totalDeducciones       Float?       @default(0)
  totalNetoPagar         Float?       @default(0)
  totalGeneral           Float?       @default(0)
  regimen                String?
  archivoUrl             String?
  // Documento de solicitud de subsidio que sube Recursos Financieros (paso 2 del flujo).
  archivoSubsidioUrl     String?
  // Reporte de asistencias quincenal firmado que sube la Jefatura Administrativa antes de
  // firmar su paso (requisito para que RH pueda hacer la nómina final).
  archivoAsistenciasUrl  String?
  // Nómina final escaneada con la firma del trabajador, que sube RH al cierre del ciclo.
  archivoNominaFinalUrl  String?
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  usuarioAutoriza     Usuario?             @relation(fields: [usuarioAutorizaId], references: [id])
  prenominas          PreNomina[]
  registrosAsistencia RegistroAsistencia[] // <--- SE AGREGÓ LA RELACIÓN FALTANTE

  @@map("nominas")
}

model PreNomina {
  id                   Int     @id @default(autoincrement())
  nominaId             Int
  empleadoId           Int
  diasTrabajados       Float   @default(15)
  horasExtra           Float   @default(0)
  sueldoBruto          Float
  compensacion         Float   @default(0)
  otrasPercepciones    Float   @default(0)
  totalPercepciones    Float
  retencionISR         Float   @default(0)
  descuentoIncidencias Float   @default(0)
  otrasDeducciones     Float   @default(0)
  totalDeducciones     Float
  totalAPagar          Float
  incidencias          String? @db.Text
  reciboFirmado        Boolean @default(false)
  urlReciboFirmado     String?

  nomina   Nomina   @relation(fields: [nominaId], references: [id])
  empleado Empleado @relation(fields: [empleadoId], references: [id])

  @@map("prenominas")
}

// ============================================================
// CRONOGRAMA DE ACTIVIDADES MÉDICAS
// ============================================================

enum TipoActividadMedica {
  INDIVIDUAL
  COMUNITARIA
}

model ActividadMedica {
  id          Int                 @id @default(autoincrement())
  titulo      String
  descripcion String?             @db.Text
  fecha       DateTime
  hora        String
  tipo        TipoActividadMedica
  responsable String
  icono       String              @default("activity")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@map("actividades_medicas")
}

// ============================================================
// AUDITORIA
// ============================================================

model Auditoria {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  accion    String // LOGIN, CREATE, UPDATE, DELETE, EXPORT
  modulo    String
  detalle   Json?
  ip        String?
  createdAt DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("auditoria")
}

// ============================================================
// NOTIFICACIONES Y ALERTAS
// ============================================================

enum TipoNotificacion {
  INFO
  ALERTA
  EXITO
  ERROR
}

model Notificacion {
  id      Int              @id @default(autoincrement())
  titulo  String
  mensaje String           @db.Text
  tipo    TipoNotificacion @default(INFO)
  leida   Boolean          @default(false)
  link    String?

  usuarioId Int?
  rol       Rol?

  createdAt DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@map("notificaciones")
}
