# Variables de entorno del servidor Marakame
# Copiar este archivo como .env y rellenar los valores

# Servidor
PORT=3000
NODE_ENV=development

# Base de datos PostgreSQL
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/marakame_db"

# JWT
JWT_SECRET=tu_jwt_secret_muy_seguro_aqui
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=tu_refresh_secret_muy_seguro_aqui
JWT_REFRESH_EXPIRES_IN=7d

# Archivos subidos (ruta local en el servidor)
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=10

# CORS - URL del frontend (en intranet)
FRONTEND_URL=http://localhost:5173

# Logs
LOG_LEVEL=info
LOG_DIR=./logs
